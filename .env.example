# ─────────────────────────────────────────────────────────────────────────────
# Discord Lyrics Status — Environment Configuration
# Salin file ini menjadi .env lalu isi nilainya
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Discord User Token kamu (JANGAN pernah share / commit ke git!)
# Cara mendapatkan: buka Discord di browser -> F12 -> Application -> Storage klik https://discord.com -> search dengan keyword token
# ke discord.com/api → lihat header "Authorization"
DISCORD_USER_TOKEN=

# Interval polling Spotify
POLL_INTERVAL_MS=800

# Port web dashboard (default: 3000)
# Buka di browser: http://localhost:3000
WEB_PORT=3000

# Mode jalankan (opsional, bisa diatur lewat CLI saat startup)
# Nilai: terminal | dashboard | both
# RUN_MODE=both

# Aktifkan debug posisi lirik (1 = aktif, 0 = nonaktif)
DEBUG_POSITION=0
