# -- Required 
# Your Discord user token (right-click profile → Copy Token in dev mode)
DISCORD_USER_TOKEN=your_discord_user_token_here

# -- Optional 
# How often to poll Spotify / SMTC (milliseconds, default 800)
POLL_INTERVAL_MS=800

# Web dashboard port (default 3000)
WEB_PORT=3000

# Auto-start mode without the interactive menu:
#   both | terminal | dashboard
# RUN_MODE=both

# Debug raw position values in the terminal
# DEBUG_POSITION=1

# -- Avatar / custom image 
# Drop any PNG (ideally with transparent background) into the ./assets/ folder,
# then set this to the filename. It will appear as a round avatar in the dashboard.
# Example: place  assets/myavatar.png  and set:
# AVATAR_FILE=myavatar.png
